<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: transparent; font-family: 'Lato', system-ui, sans-serif; overflow: hidden; height: auto; }
  body { display: block; }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(2.2); opacity: 0; }
  }
  @keyframes countUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
<body>

<!-- ══ NAUTICAL MILES — fact box ══ -->
<div style="background:linear-gradient(135deg,#e6f7fd,#d6f0fb);border:1px solid #b3e4f5;border-radius:14px;padding:22px 28px;display:flex;align-items:center;gap:24px;">
  <div id="nautical-miles" style="font-size:46px;font-weight:900;line-height:1;letter-spacing:-2px;color:#009ada;font-variant-numeric:tabular-nums;animation:countUp 0.6s ease forwards">0</div>
  <div style="flex:1">
    <div style="font-size:16px;font-weight:700;color:#1f3140;margin-bottom:4px">Nautical miles sailed this year</div>
    <div style="font-size:13px;color:#3d7a95">Whole fleet — from the North Sea to Australia</div>
  </div>
  <div style="display:flex;align-items:center;gap:8px;background:rgba(0,154,218,0.1);border:1px solid rgba(0,154,218,0.25);border-radius:20px;padding:8px 18px;flex-shrink:0">
    <div style="position:relative;width:8px;height:8px">
      <div style="width:8px;height:8px;border-radius:50%;background:#009ada;position:relative;z-index:1"></div>
      <div style="position:absolute;top:0;left:0;width:8px;height:8px;border-radius:50%;background:#009ada;opacity:0.35;animation:pulse 2s ease infinite"></div>
    </div>
    <span style="font-size:12px;font-weight:700;color:#009ada;letter-spacing:0.4px">LIVE FLEET</span>
  </div>
</div>

<script>
  (function() {
    var el = document.getElementById('nautical-miles');
    if (!el) return;
    var target = 148520, dur = 2200, t0 = Date.now();
    function tick() {
      var p = Math.min((Date.now() - t0) / dur, 1);
      var e = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(e * target).toLocaleString('en-US');
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  })();
</script>

</body>
</html>
